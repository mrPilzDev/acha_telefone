<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Extrator de Telefones</title>

<style>
    body { font-family: Arial; margin: 20px; }
    textarea { width: 100%; height: 150px; margin-bottom: 10px; }
    button { margin-right: 10px; padding: 8px 12px; }
    #contador { font-weight: bold; margin-bottom: 10px; }
</style>
</head>

<body>

<h2>Área 1 (Cole o texto)</h2>
<textarea id="area1"></textarea>

<button onclick="limpar()">Limpar</button>
<button onclick="exportar()">Exportar Excel</button>

<h2>Telefones encontrados</h2>
<div id="contador">Total: 0</div>
<textarea id="area2" readonly></textarea>

<script>

function extrairTelefones(texto) {

    let textoLimpo = texto.replace(/<[^>]*>/g, '');

    const regex = /(\+55\s?)?\(?\d{2}\)?\s?9?\d{4}-?\d{4}/g;

    let encontrados = textoLimpo.match(regex);

    if (!encontrados) return [];

    encontrados = encontrados.map(tel =>
        tel.replace(/\D/g, '')
    );

    // remove código país
    encontrados = encontrados.map(tel =>
        tel.startsWith('55') ? tel.substring(2) : tel
    );

    // 🔥 FILTRO DDD + CELULAR
    encontrados = encontrados.filter(tel =>
        tel.length === 11 &&
        tel[2] === '9' &&
        (tel.startsWith('44') || tel.startsWith('45'))
    );

    return [...new Set(encontrados)];
}


// 🔥 ATUALIZA AUTOMÁTICO
document.getElementById('area1').addEventListener('input', atualizar);

function atualizar() {
    let texto = document.getElementById('area1').value;

    let telefones = extrairTelefones(texto);

    document.getElementById('area2').value =
        telefones.length ? telefones.join('\n') : '';

    document.getElementById('contador').innerText =
        'Total: ' + telefones.length;
}


// 🔥 LIMPAR
function limpar() {
    document.getElementById('area1').value = '';
    document.getElementById('area2').value = '';
    document.getElementById('contador').innerText = 'Total: 0';
}


// 🔥 EXPORTAR CSV (abre no Excel)
function exportar() {

    let conteudo = document.getElementById('area2').value;

    if (!conteudo) {
        alert('Nenhum número para exportar');
        return;
    }

    // 🔥 evita split pesado se já está em linhas
    let csv = "Telefone\n" + conteudo;

    let blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });

    let link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = "telefones.csv";

    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}


</script>

</body>
</html>
